# AI DevBox – compose environment variables.
# Copy this file to .env and fill in values, then run docker compose normally.
# .env is loaded automatically by docker compose.
#
# Recommended: use ./container/compose-up.sh which computes these automatically
# as (host cores - 1), minimum 1. Only set these manually if you use bare
# docker compose commands.

# Build parallelism – number of parallel jobs for CMake and Qbs builds.
# Set to (number of CPU cores - 1) for desktop responsiveness.
CMAKE_BUILD_PARALLEL_LEVEL=
AI_DEVBOX_BUILD_JOBS=

# Base image URL for the advanced service.
# Default: nvcr.io/nvidia/deepstream:9.0-triton-multiarch (Ubuntu 24.04, CUDA 12.6)
# This indirectly controls the Ubuntu version inside the container.
# For reproducible builds, prefer a fully pinned image reference with a digest.
ADVANCED_BASE_IMAGE_URL=

# GCC version for the advanced service.
# Default: 14
ADVANCED_GCC_VERSION=14

# CMake version for the advanced service.
# Default: 4.2.2
ADVANCED_CMAKE_VERSION=4.2.2

# Skip full OS upgrade during Docker image build (1 = skip, 0 = upgrade).
# Set to 1 to speed up iterative rebuilds.
SKIP_OS_UPGRADE=0

# ccache cache size directory maximum size.
# Default: 20G
CCACHE_MAXSIZE=20G

# SHA256 for LibTorch download verification (recommended).
# Find the checksum at: https://download.pytorch.org/libtorch/
TORCH_SHA256=

# Require TORCH_SHA256 during builds (1 = require checksum, 0 = allow empty).
REQUIRE_TORCH_SHA256=0

# ---------------------------------------------------------------------------
# ZED SDK – used by the zed and zed-gl services.
# ---------------------------------------------------------------------------

# Base image URL for the zed / zed-gl services.
# Default: nvcr.io/nvidia/deepstream:9.0-triton-multiarch (Ubuntu 24.04, CUDA 12.6)
# NOTE: Ubuntu version is auto-detected from the base image at build time;
#       do not pass a mismatched UBUNTU_RELEASE_YEAR manually.
ZED_BASE_IMAGE_URL=

# GCC version for the zed / zed-gl services.
# Default: 14
ZED_GCC_VERSION=14

# CMake version for the zed / zed-gl services.
# Default: 3.31.0
ZED_CMAKE_VERSION=3.31.0

# ZED SDK major and minor version to install.
# Check available releases at: https://www.stereolabs.com/developers/release
ZED_SDK_MAJOR=5
ZED_SDK_MINOR=2

# CUDA major version expected by the ZED SDK installer (must match the base image).
# cu12 is compatible with any CUDA 12.x runtime (including 12.6 from DS 9.0).
ZED_CUDA_MAJOR=12

# Host NVIDIA driver installation defaults used by setup/01_nvidia_drivers.sh.
NVIDIA_DRIVER_VERSION=590
NVIDIA_DRIVER_FLAVOR=open

